rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function isNonNegativeInt(v) {
      return v is int && v >= 0;
    }

    function isNonEmptyString(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    match /gameStats/{gameId} {
      allow read: if true;

      allow create, update: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'name', 'path', 'image', 'type', 'sourceBase',
          'plays', 'uniqueClicks', 'currentPlayers',
          'thumbsUp', 'thumbsDown',
          'updatedAt'
        ])
        && isNonNegativeInt(request.resource.data.plays)
        && isNonNegativeInt(request.resource.data.uniqueClicks)
        && isNonNegativeInt(request.resource.data.currentPlayers)
        && isNonNegativeInt(request.resource.data.thumbsUp)
        && isNonNegativeInt(request.resource.data.thumbsDown)
        && (!('name' in request.resource.data) || request.resource.data.name is string)
        && (!('path' in request.resource.data) || request.resource.data.path is string)
        && (!('image' in request.resource.data) || request.resource.data.image is string)
        && (!('type' in request.resource.data) || request.resource.data.type is string)
        && (!('sourceBase' in request.resource.data) || request.resource.data.sourceBase is string);
    }

    match /gameStats/{gameId}/players/{uid} {
      allow read: if isOwner(uid);

      allow create, update: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, [
          'uid',
          'rating', 'lastPlayedAt', 'lastRatedAt', 'clickCount',
          'activeSession', 'activeGamePath', 'activeAt',
          'gamePath', 'gameName', 'gameImage', 'sourceBase',
          'isFavorite', 'favoritedAt'
        ])
        && (!('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid)
        && (!('rating' in request.resource.data) || (request.resource.data.rating is int && request.resource.data.rating in [-1, 0, 1]))
        && (!('clickCount' in request.resource.data) || isNonNegativeInt(request.resource.data.clickCount))
        && (!('activeSession' in request.resource.data) || isNonEmptyString(request.resource.data.activeSession, 200))
        && (!('activeGamePath' in request.resource.data) || request.resource.data.activeGamePath is string)
        && (!('gamePath' in request.resource.data) || request.resource.data.gamePath is string)
        && (!('gameName' in request.resource.data) || request.resource.data.gameName is string)
        && (!('gameImage' in request.resource.data) || request.resource.data.gameImage is string)
        && (!('sourceBase' in request.resource.data) || request.resource.data.sourceBase is string)
        && (!('isFavorite' in request.resource.data) || request.resource.data.isFavorite is bool)
        && (!('favoritedAt' in request.resource.data) || request.resource.data.favoritedAt is timestamp);

      allow delete: if isOwner(uid);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, [
          'uid', 'emailHash', 'providers', 'usernameHash', 'usernameChangedAt', 'updatedAt',
          'email', 'username', 'usernameLower', 'settings', 'gameProgress', 'lastManualSyncAt', 'lastAutoSyncAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && (!('emailHash' in request.resource.data) || isNonEmptyString(request.resource.data.emailHash, 128))
        && (!('usernameHash' in request.resource.data) || isNonEmptyString(request.resource.data.usernameHash, 128))
        && (!('usernameChangedAt' in request.resource.data) || request.resource.data.usernameChangedAt is timestamp)
        && (!('providers' in request.resource.data) || request.resource.data.providers is list)
        && (!('email' in request.resource.data) || request.resource.data.email is string)
        && (!('username' in request.resource.data) || request.resource.data.username is string)
        && (!('usernameLower' in request.resource.data) || request.resource.data.usernameLower is string)
        && (!('settings' in request.resource.data) || request.resource.data.settings is map)
        && (!('gameProgress' in request.resource.data) || request.resource.data.gameProgress is map)
        && (!('lastManualSyncAt' in request.resource.data) || request.resource.data.lastManualSyncAt is timestamp)
        && (!('lastAutoSyncAt' in request.resource.data) || request.resource.data.lastAutoSyncAt is timestamp);

      allow update: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, [
          'uid', 'emailHash', 'providers', 'usernameHash', 'usernameChangedAt', 'updatedAt',
          'email', 'username', 'usernameLower', 'settings', 'gameProgress', 'lastManualSyncAt', 'lastAutoSyncAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && (!('emailHash' in request.resource.data) || isNonEmptyString(request.resource.data.emailHash, 128))
        && (!('usernameHash' in request.resource.data) || isNonEmptyString(request.resource.data.usernameHash, 128))
        && (!('providers' in request.resource.data) || request.resource.data.providers is list)
        && (!('email' in request.resource.data) || request.resource.data.email is string)
        && (!('username' in request.resource.data) || request.resource.data.username is string)
        && (!('usernameLower' in request.resource.data) || request.resource.data.usernameLower is string)
        && (!('settings' in request.resource.data) || request.resource.data.settings is map)
        && (!('gameProgress' in request.resource.data) || request.resource.data.gameProgress is map)
        && (!('lastManualSyncAt' in request.resource.data) || request.resource.data.lastManualSyncAt is timestamp)
        && (!('lastAutoSyncAt' in request.resource.data) || request.resource.data.lastAutoSyncAt is timestamp)
        && (
          request.resource.data.usernameHash == resource.data.usernameHash
          || (
            ('usernameChangedAt' in request.resource.data)
            && request.resource.data.usernameChangedAt == request.time
            && (
              !('usernameChangedAt' in resource.data)
              || !(resource.data.usernameChangedAt is timestamp)
              || request.time >= resource.data.usernameChangedAt + duration.value(7, 'd')
            )
          )
        )
        && (
          !('lastManualSyncAt' in request.resource.data)
          || !('lastManualSyncAt' in resource.data)
          || !(resource.data.lastManualSyncAt is timestamp)
          || request.resource.data.lastManualSyncAt == resource.data.lastManualSyncAt
          || (
            request.resource.data.lastManualSyncAt == request.time
            && request.time >= resource.data.lastManualSyncAt + duration.value(5, 'm')
          )
        )
        && (
          !('lastAutoSyncAt' in request.resource.data)
          || !('lastAutoSyncAt' in resource.data)
          || !(resource.data.lastAutoSyncAt is timestamp)
          || request.resource.data.lastAutoSyncAt == resource.data.lastAutoSyncAt
          || (
            request.resource.data.lastAutoSyncAt == request.time
            && request.time >= resource.data.lastAutoSyncAt + duration.value(30, 'm')
          )
        );

      allow delete: if isOwner(uid);
    }

    match /usernames/{usernameHash} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn()
        && hasOnlyKeys(request.resource.data, ['uid', 'usernameHash', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameHash == usernameHash
        && isNonEmptyString(request.resource.data.usernameHash, 128)
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.usernameHash == usernameHash;

      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
