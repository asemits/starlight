rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function isNonEmptyString(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    function isStringMax(v, maxLen) {
      return v is string && v.size() <= maxLen;
    }

    function hasKey(data, key) {
      return data.keys().hasAny([key]);
    }

    function isHandle(v) {
      return v is string
        && v.size() >= 2
        && v.size() <= 40
        && v.matches('^@[a-z0-9_]+$');
    }

    function intOrZero(v) {
      return v is int ? v : 0;
    }

    function isTopicName(v) {
      return v is string
        && v.size() >= 3
        && v.size() <= 31
        && v.matches('^[a-z0-9][a-z0-9-]*$');
    }

    function isTopicOwner(topicId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/feedTopics/$(topicId)).data.ownerId == request.auth.uid;
    }

    match /feedRateLimits/{uid} {
      allow read: if isOwner(uid);

      allow create, update: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, ['uid', 'lastCreatedAt', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.lastCreatedAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow delete: if false;
    }

    match /feedTopicNames/{nameLower} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && isTopicName(nameLower)
        && !exists(/databases/$(database)/documents/feedTopicNames/$(nameLower))
        && hasOnlyKeys(request.resource.data, ['nameLower', 'topicId', 'ownerId', 'createdAt'])
        && request.resource.data.nameLower == nameLower
        && isNonEmptyString(request.resource.data.topicId, 128)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdAt is timestamp;

      allow update: if false;

      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /feedTopics/{topicId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'name', 'nameLower', 'description', 'rules',
          'ownerId', 'ownerName', 'createdAt', 'updatedAt'
        ])
        && isTopicName(request.resource.data.name)
        && request.resource.data.nameLower == request.resource.data.name
        && isNonEmptyString(request.resource.data.description, 300)
        && isNonEmptyString(request.resource.data.rules, 800)
        && request.resource.data.ownerId == request.auth.uid
        && isNonEmptyString(request.resource.data.ownerName, 60)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && hasOnlyKeys(request.resource.data, [
          'name', 'nameLower', 'description', 'rules',
          'ownerId', 'ownerName', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.ownerName == resource.data.ownerName
        && request.resource.data.createdAt == resource.data.createdAt
        && isTopicName(request.resource.data.name)
        && request.resource.data.nameLower == request.resource.data.name
        && isNonEmptyString(request.resource.data.description, 300)
        && isNonEmptyString(request.resource.data.rules, 800)
        && request.resource.data.updatedAt is timestamp;

      allow delete: if false;
    }

    match /feedTopics/{topicId}/members/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, ['uid', 'role', 'favorite', 'joinedAt', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.favorite is bool
        && request.resource.data.joinedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.role == 'member'
          || (
            request.resource.data.role == 'owner'
            && uid == get(/databases/$(database)/documents/feedTopics/$(topicId)).data.ownerId
          )
        );

      allow update: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, ['uid', 'role', 'favorite', 'joinedAt', 'updatedAt'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.favorite is bool
        && request.resource.data.updatedAt is timestamp;

      allow delete: if isOwner(uid)
        && resource.data.role != 'owner';
    }

    match /feedThreads/{threadId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'topicId', 'title', 'body', 'authorId', 'authorName',
          'createdAt', 'updatedAt', 'commentCount', 'deletedAt', 'deletedBy'
        ])
        && isNonEmptyString(request.resource.data.topicId, 128)
        && exists(/databases/$(database)/documents/feedTopics/$(request.resource.data.topicId))
        && isNonEmptyString(request.resource.data.title, 160)
        && isNonEmptyString(request.resource.data.body, 4000)
        && request.resource.data.authorId == request.auth.uid
        && isNonEmptyString(request.resource.data.authorName, 60)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.commentCount == 0
        && request.resource.data.deletedAt == null
        && request.resource.data.deletedBy == '';

      allow update: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'topicId', 'title', 'body', 'authorId', 'authorName',
          'createdAt', 'updatedAt', 'commentCount', 'deletedAt', 'deletedBy'
        ])
        && request.resource.data.topicId == resource.data.topicId
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.authorName == resource.data.authorName
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            request.auth.uid == resource.data.authorId
            && isNonEmptyString(request.resource.data.title, 160)
            && isNonEmptyString(request.resource.data.body, 4000)
            && request.resource.data.commentCount == resource.data.commentCount
            && request.resource.data.deletedAt == resource.data.deletedAt
            && request.resource.data.deletedBy == resource.data.deletedBy
            && request.resource.data.updatedAt is timestamp
          )
          ||
          (
            request.resource.data.commentCount is int
            && resource.data.commentCount is int
            && request.resource.data.commentCount == resource.data.commentCount + 1
            && request.resource.data.title == resource.data.title
            && request.resource.data.body == resource.data.body
            && request.resource.data.deletedAt == resource.data.deletedAt
            && request.resource.data.deletedBy == resource.data.deletedBy
            && request.resource.data.updatedAt is timestamp
          )
          ||
          (
            (request.auth.uid == resource.data.authorId || isTopicOwner(resource.data.topicId))
            && request.resource.data.title == resource.data.title
            && request.resource.data.commentCount == resource.data.commentCount
            && request.resource.data.body == '[removed by moderator]'
            && request.resource.data.deletedAt is timestamp
            && request.resource.data.deletedBy == request.auth.uid
            && request.resource.data.updatedAt is timestamp
          )
        );

      allow delete: if false;
    }

    match /feedThreads/{threadId}/votes/{uid} {
      allow read: if isSignedIn();

      allow create, update: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, ['uid', 'value', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.value is int
        && request.resource.data.value in [-1, 1]
        && request.resource.data.updatedAt is timestamp;

      allow delete: if isOwner(uid);
    }

    match /feedThreads/{threadId}/comments/{commentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'parentId', 'body', 'authorId', 'authorName',
          'createdAt', 'updatedAt', 'deletedAt', 'deletedBy'
        ])
        && request.resource.data.authorId == request.auth.uid
        && isNonEmptyString(request.resource.data.authorName, 60)
        && request.resource.data.parentId is string
        && request.resource.data.parentId.size() <= 200
        && isNonEmptyString(request.resource.data.body, 2000)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.deletedAt == null
        && request.resource.data.deletedBy == ''
        && get(/databases/$(database)/documents/feedThreads/$(threadId)).data.deletedAt == null
        && (
          request.resource.data.parentId == ''
          || exists(/databases/$(database)/documents/feedThreads/$(threadId)/comments/$(request.resource.data.parentId))
        );

      allow update: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'parentId', 'body', 'authorId', 'authorName',
          'createdAt', 'updatedAt', 'deletedAt', 'deletedBy'
        ])
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.authorName == resource.data.authorName
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            request.auth.uid == resource.data.authorId
            && isNonEmptyString(request.resource.data.body, 2000)
            && request.resource.data.deletedAt == resource.data.deletedAt
            && request.resource.data.deletedBy == resource.data.deletedBy
            && request.resource.data.updatedAt is timestamp
          )
          ||
          (
            (request.auth.uid == resource.data.authorId || isTopicOwner(get(/databases/$(database)/documents/feedThreads/$(threadId)).data.topicId))
            && request.resource.data.body == '[removed by moderator]'
            && request.resource.data.deletedAt is timestamp
            && request.resource.data.deletedBy == request.auth.uid
            && request.resource.data.updatedAt is timestamp
          )
        );

      allow delete: if false;
    }

    match /feedThreads/{threadId}/comments/{commentId}/votes/{uid} {
      allow read: if isSignedIn();

      allow create, update: if isOwner(uid)
        && hasOnlyKeys(request.resource.data, ['uid', 'value', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.value is int
        && request.resource.data.value in [-1, 1]
        && request.resource.data.updatedAt is timestamp;

      allow delete: if isOwner(uid);
    }

    match /feedPosts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 300
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 4000
        && request.resource.data.community is string
        && request.resource.data.community.size() > 0
        && request.resource.data.community.size() <= 48
        && request.resource.data.flair is string
        && request.resource.data.flair.size() > 0
        && request.resource.data.flair.size() <= 32
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.authorHandle is string
        && request.resource.data.authorHandle.size() > 0
        && request.resource.data.authorHandle.size() <= 40
        && request.resource.data.commentCount == 0
        && (!('likesCount' in request.resource.data) || (request.resource.data.likesCount is int && request.resource.data.likesCount >= 0))
        && request.resource.data.createdAt is timestamp
        && request.resource.data.lastActivityAt is timestamp;

      allow update: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'title', 'body', 'community', 'flair',
          'authorId', 'authorName', 'authorHandle',
          'commentCount', 'likesCount', 'createdAt', 'lastActivityAt'
        ])
        && request.resource.data.title == resource.data.title
        && request.resource.data.body == resource.data.body
        && request.resource.data.community == resource.data.community
        && request.resource.data.flair == resource.data.flair
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.authorName == resource.data.authorName
        && request.resource.data.authorHandle == resource.data.authorHandle
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            request.resource.data.commentCount is int
            && resource.data.commentCount is int
            && request.resource.data.commentCount == resource.data.commentCount + 1
            && request.resource.data.lastActivityAt is timestamp
            && request.resource.data.likesCount == resource.data.likesCount
          )
          ||
          (
            request.resource.data.commentCount == resource.data.commentCount
            && request.resource.data.lastActivityAt == resource.data.lastActivityAt
            && request.resource.data.likesCount is int
            && request.resource.data.likesCount >= 0
            && (
              request.resource.data.likesCount == intOrZero(resource.data.likesCount) + 1
              || request.resource.data.likesCount == intOrZero(resource.data.likesCount) - 1
            )
          )
        );

      allow delete: if false;
    }

    match /feedPosts/{postId}/comments/{commentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasOnlyKeys(request.resource.data, [
          'parentId', 'authorId', 'authorName', 'authorHandle', 'body', 'createdAt'
        ])
        && request.resource.data.authorId == request.auth.uid
        && isNonEmptyString(request.resource.data.authorName, 80)
        && isHandle(request.resource.data.authorHandle)
        && request.resource.data.parentId is string
        && request.resource.data.parentId.size() <= 200
        && isNonEmptyString(request.resource.data.body, 2000)
        && request.resource.data.createdAt is timestamp
        && (
          request.resource.data.parentId == ''
          || exists(/databases/$(database)/documents/feedPosts/$(postId)/comments/$(request.resource.data.parentId))
        );

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
